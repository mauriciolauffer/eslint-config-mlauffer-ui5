{
  "name": "eslint-config-mlauffer-ui5",
  "version": "2.1.0",
  "private": false,
  "description": "ESLint shareable config for UI5",
  "keywords": [
    "config",
    "eslint",
    "javascript",
    "openui5",
    "sapui5",
    "ui5"
  ],
  "bugs": {
    "url": "https://github.com/mauriciolauffer/eslint-config-mlauffer-ui5.git/issues"
  },
  "license": "MIT",
  "author": "Mauricio Lauffer",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mauriciolauffer/eslint-config-mlauffer-ui5.git"
  },
  "files": [
    "lib"
  ],
  "type": "module",
  "main": "lib/index.js",
  "scripts": {
    "lint": "oxfmt --check && eslint . --cache",
    "lint:ci": "eslint . -f @microsoft/eslint-formatter-sarif -o eslint.sarif",
    "format": "oxfmt --write",
    "test": "vitest run"
  },
  "dependencies": {
    "eslint-config-mlauffer-nodejs": "^3.1.1",
    "eslint-plugin-no-unsanitized": "^4.1.4",
    "globals": "^17.3.0"
  },
  "devDependencies": {
    "@eslint/config-inspector": "^1.4.2",
    "@types/eslint": "^9.6.1",
    "@types/node": "^24.10.13",
    "eslint": "^9.39.2",
    "oxfmt": "^0.33.0",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.30.0"
}
